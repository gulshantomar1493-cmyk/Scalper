# MarketScalper production environment (roadmap P0.27).
# Copy to /etc/marketscalper/env on the server and fill the secrets.
# NO real values in git, ever (D3). Config precedence: config.example.yaml
# -> backend/config.yaml -> these environment variables (highest).

# --- secrets (required) ---
MARKETSCALPER_DB_DSN=
MARKETSCALPER_API_TOKEN=

# --- login (single-user tool) ---
# Username + password for the web login. The user signs in once; the backend
# validates against these and returns MARKETSCALPER_API_TOKEN, which the browser
# stores (localStorage) and sends as the Bearer on every request. Unset -> the
# /login endpoint answers 503 (login disabled; a ?token= URL still works for dev).
MARKETSCALPER_AUTH_USER=
MARKETSCALPER_AUTH_PASSWORD=

# --- launch settings (defaults shown) ---
MARKETSCALPER_API_HOST=127.0.0.1
MARKETSCALPER_API_PORT=8000
MARKETSCALPER_FEED=binance
MARKETSCALPER_LOG_LEVEL=INFO
MARKETSCALPER_LOG_DIR=/var/log/marketscalper

# --- planning (D21.5) ---
# Account equity for the §7 SUGGESTED qty display (0.5% risk sizing).
# Display-only — the platform never places orders; net RR admission is
# equity-independent.
MARKETSCALPER_EQUITY_USD=10000

