# MarketScalper production environment (roadmap P0.27).
# Copy to /etc/marketscalper/env on the server and fill the secrets.
# NO real values in git, ever (D3). Config precedence: config.example.yaml
# -> backend/config.yaml -> these environment variables (highest).

# --- secrets (required) ---
MARKETSCALPER_DB_DSN=
MARKETSCALPER_API_TOKEN=

# --- launch settings (defaults shown) ---
MARKETSCALPER_API_HOST=127.0.0.1
MARKETSCALPER_API_PORT=8000
MARKETSCALPER_FEED=binance
MARKETSCALPER_LOG_LEVEL=INFO
MARKETSCALPER_LOG_DIR=/var/log/marketscalper
